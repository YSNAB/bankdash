// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User roles enum
enum UserRole {
  ADMIN
  EMPLOYEE
}

// User authentication model
model User {
  id             String    @id @default(cuid())
  username       String    @unique
  password       String    // Store hashed password (use bcrypt)
  pin            String?   // PIN for POS login (4-6 digits, hashed with bcrypt)
  name           String?
  role           UserRole  @default(EMPLOYEE)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Products model
model Product {
  id              Int              @id @default(autoincrement())
  name            String
  ean             String?
  conditionRegion String?          @map("condition_region")
  brandSerie      String?          @map("brand_serie")
  model           String?
  storage         String?
  color           String?
  fullname        String?          @map("fullname")
  sellingPrice    Float?           @map("selling_price")
  currentStock    Int              @default(0) @map("current_stock")
  minimalStock    Int?             @map("minimal_stock")
  purchaseDetails PurchaseDetail[] @relation("ProductToPurchaseDetail")
  orderDetails    OrderDetail[]    @relation("ProductToOrderDetail")
  stockMovements  StockMovement[]


  @@map("products")
}

// Suppliers model
model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  purchases Purchase[] @relation("SupplierToPurchase")

  @@map("suppliers")
}

// Customers model
model Customer {
  id          Int     @id @default(autoincrement())
  name        String
  companyName String? @map("company_name")
  location    String? // City
  region      String  @default("NL") // NL, EU, or Non-EU
  orders      Order[] @relation("CustomerToOrder")

  @@map("customers")
}

// Purchases (orders) model
model Purchase {
  id              Int              @id @default(autoincrement())
  supplierId      Int              @map("supplier_id")
  date            DateTime         @db.Timestamptz(6)
  supplier        Supplier         @relation("SupplierToPurchase", fields: [supplierId], references: [id])
  purchaseDetails PurchaseDetail[] @relation("PurchaseToPurchaseDetail")

  @@map("purchases")
}

// Purchase details (order line items) model
model PurchaseDetail {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  productId Int      @map("product_id")
  quantity  Int
  price     Float
  type      String?
  purchase  Purchase @relation("PurchaseToPurchaseDetail", fields: [orderId], references: [id])
  product   Product  @relation("ProductToPurchaseDetail", fields: [productId], references: [id])

  @@map("purchase_details")
}

// Orders model (customer orders)
model Order {
  id          Int           @id @default(autoincrement())
  customerId  Int           @map("customer_id")
  date        DateTime      @db.Timestamptz(6)
  paymentType String        @map("payment_type") // "cash" or "factuur"
  paidAmount  Float         @default(0) @map("paid_amount")
  customer    Customer      @relation("CustomerToOrder", fields: [customerId], references: [id])
  orderDetails OrderDetail[] @relation("OrderToOrderDetail")

  @@map("orders")
}

// Order details (customer order line items) model
model OrderDetail {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int
  price     Float
  order     Order   @relation("OrderToOrderDetail", fields: [orderId], references: [id])
  product   Product @relation("ProductToOrderDetail", fields: [productId], references: [id])

  @@map("order_details")
}

// Stock movements model
enum MovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  STOCKTAKE
}

model StockMovement {
  id              Int          @id @default(autoincrement())
  productId       Int          @map("product_id")
  datetime        DateTime     @default(now()) @db.Timestamptz(6)
  quantity        Int // Positive = in, Negative = out
  type            MovementType
  reference       String? // Optional reference like "PO-123" or "SALE-456"
  purchaseOrderId Int?         @map("purchase_order_id")
  notes           String?
  product         Product      @relation(fields: [productId], references: [id])

  @@map("stock_movements")
  @@index([productId])
  @@index([datetime])
}
